# CampusEcho V1 - Backend Environment Configuration

# FastAPI Settings
APP_NAME="CampusEcho Backend"
APP_ENV=development
DEBUG=True

# Supabase Credentials (from Supabase Project Settings API keys check)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Token Secret for Backend Auth Validation
JWT_SECRET_KEY=your_super_secret_jwt_key_here_minimum_32_characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
